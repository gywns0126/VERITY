# ── VERITY_MODE: 환경 분기 ──────────────────────────────────
# dev     : 모든 AI API + 유료 데이터 수집기 mock (비용 0원)
# staging : VERITY_STAGING_REAL_KEYS에 지정된 키만 실호출, 나머지 mock
# prod    : 전부 실호출 (GitHub Actions에서 자동 설정)
VERITY_MODE=dev
VERITY_STAGING_REAL_KEYS=gemini.daily_report,gemini.periodic_report

# ── AI API 키 ──────────────────────────────────────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# ── 유료 데이터 API 키 ────────────────────────────────────
FINNHUB_API_KEY=
POLYGON_API_KEY=
NEWS_API_KEY=

# ── 무료 (VERITY_MODE 영향 없음) ──────────────────────────
# FRED_API_KEY=
# DART_API_KEY=
# KRX_DATA_API_KEY=

# ── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── 트레이싱 ──────────────────────────────────────────────
TRACE_ENABLED=1
TRACE_AI_CALLS=1

# ── Chat Hybrid (Brain + Perplexity + Gemini Grounding + Claude) ────
# 롤백 스위치 — false 면 기존 Gemini 단일 경로 유지
CHAT_HYBRID_ENABLED=false
# 합성 모델 (기본: CLAUDE_MODEL_DEFAULT=claude-sonnet-4-6)
# CHAT_HYBRID_SYNTH_MODEL=claude-sonnet-4-6
# CHAT_HYBRID_SYNTH_MAX_TOKENS=800
# 분류기 모델 (저렴한 lite 사용)
# CHAT_HYBRID_CLASSIFIER_MODEL=gemini-2.5-flash-lite
# Grounding 모델
# CHAT_HYBRID_GROUNDING_MODEL=gemini-2.5-flash-lite
# 타임아웃 (초)
# CHAT_HYBRID_PERPLEXITY_TIMEOUT=5
# CHAT_HYBRID_GROUNDING_TIMEOUT=4
# CHAT_HYBRID_EXTERNAL_TIMEOUT=6
# CHAT_HYBRID_DEADLINE_SEC=12
# Rate limit — per-user 분당, 글로벌 일일 (비용 cap)
# CHAT_HYBRID_PER_MIN_CAP=10
# CHAT_HYBRID_DAILY_CAP=500
