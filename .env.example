# ── VERITY_MODE: 환경 분기 ──────────────────────────────────
# dev     : 모든 AI API + 유료 데이터 수집기 mock (비용 0원)
# staging : VERITY_STAGING_REAL_KEYS에 지정된 키만 실호출, 나머지 mock
# prod    : 전부 실호출 (GitHub Actions에서 자동 설정)
VERITY_MODE=dev
VERITY_STAGING_REAL_KEYS=gemini.daily_report,gemini.periodic_report

# ── AI API 키 ──────────────────────────────────────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# ── 유료 데이터 API 키 ────────────────────────────────────
FINNHUB_API_KEY=
POLYGON_API_KEY=
NEWS_API_KEY=

# ── 무료 (VERITY_MODE 영향 없음) ──────────────────────────
# FRED_API_KEY=
# DART_API_KEY=
# KRX_DATA_API_KEY=

# ── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── 트레이싱 ──────────────────────────────────────────────
TRACE_ENABLED=1
TRACE_AI_CALLS=1
