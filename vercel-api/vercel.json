    { "source": "/api/estate/health",            "destination": "/api/estate_health" },
    { "source": "/api/estate/landex-pulse",      "destination": "/api/estate_landex_pulse" },
    { "source": "/api/estate/change-feed",       "destination": "/api/estate_change_feed" },
    { "source": "/api/estate/policy-shock",      "destination": "/api/estate_policy_shock" },
    { "source": "/api/estate/subscription-calendar", "destination": "/api/estate_subscription_calendar" },
    { "source": "/api/estate/tax-simulator",      "destination": "/api/estate_tax_simulator" },
    { "source": "/api/estate/macro-bridge",       "destination": "/api/estate_macro_bridge" },
    { "source": "/api/estate/brain",             "destination": "/api/estate_brain" },
    { "source": "/api/estate/horizon",           "destination": "/api/estate_horizon" },
    { "source": "/api/estate/watch-complexes",   "destination": "/api/estate_watch_complexes" },
    { "source": "/api/verity/us-financials",     "destination": "/api/us_financials" }
  ],
  "headers": [
    {
      "source": "/api/((?!order(?:$|/))(?!chat(?:$|/))(?!watchgroups(?:$|/))(?!reports(?:$|/)).*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PATCH, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, X-Admin-Token" }
      ]
    }
  ]
}
