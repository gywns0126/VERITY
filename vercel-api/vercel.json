{
  "cleanUrls": true,
  "ignoreCommand": "bash -c 'cd .. || exit 0; git rev-parse HEAD^ >/dev/null 2>&1 || exit 0; git diff --quiet HEAD^ HEAD -- vercel-api/ && exit 0; exit 1'",
  "functions": {
    "api/stock.py": { "maxDuration": 30 },
    "api/stock_detail.py": { "maxDuration": 30 },
    "api/search.py": { "maxDuration": 5 },
    "api/chat.py": { "maxDuration": 60 },
    "api/chat_diag.py": { "maxDuration": 5 },
    "api/watchgroups.py": { "maxDuration": 10 },
    "api/order.py": { "maxDuration": 10 },
    "api/chart.py": { "maxDuration": 10 },
    "api/visitor_ping.py": { "maxDuration": 5 },
    "api/admin.py": { "maxDuration": 15 },
    "api/system_health.py": { "maxDuration": 5 },
    "api/estate_corp_holdings.py": { "maxDuration": 5 },
    "api/estate_corp_by_region.py": { "maxDuration": 8 },
    "api/estate_corp_asset_discount.py": { "maxDuration": 8 },
    "api/estate_corp_facilities.py": { "maxDuration": 8 },
    "api/estate_corp_disposals.py": { "maxDuration": 10 },
    "api/estate_macro_bridge.py": { "maxDuration": 5 },
    "api/corp_probe.py": { "maxDuration": 10 },
    "api/reports.py": { "maxDuration": 10 },
    "api/us_financials.py": { "maxDuration": 5 },
    "api/cron/dispatch_pulse.py": { "maxDuration": 10 }
  },
  "crons": [
    { "path": "/api/cron/dispatch_pulse", "schedule": "* * * * *" }
  ],
  "rewrites": [
    { "source": "/api/estate/corp-holdings",     "destination": "/api/estate_corp_holdings" },
    { "source": "/api/estate/corp-by-region",    "destination": "/api/estate_corp_by_region" },
    { "source": "/api/estate/corp-asset-discount", "destination": "/api/estate_corp_asset_discount" },
    { "source": "/api/estate/corp-facilities",   "destination": "/api/estate_corp_facilities" },
    { "source": "/api/estate/corp-disposals",    "destination": "/api/estate_corp_disposals" },
    { "source": "/api/estate/macro-bridge",       "destination": "/api/estate_macro_bridge" },
    { "source": "/api/system/health",            "destination": "/api/system_health" },
    { "source": "/api/verity/us-financials",     "destination": "/api/us_financials" }
  ],
  "headers": [
    {
      "source": "/api/((?!order(?:$|/))(?!chat(?:$|/))(?!watchgroups(?:$|/))(?!reports(?:$|/)).*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PATCH, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, X-Admin-Token" }
      ]
    }
  ]
}
