    "api/estate_corp_asset_discount.py": { "maxDuration": 8 },
    "api/estate_corp_facilities.py": { "maxDuration": 8 },
    "api/estate_corp_disposals.py": { "maxDuration": 10 },
    "api/estate_commercial_pulse.py": { "maxDuration": 5 },
    "api/estate_sector_pulse.py": { "maxDuration": 5 },
    "api/estate_hero_briefing.py": { "maxDuration": 5 },
    "api/system_health.py": { "maxDuration": 5 },
    "api/estate_health.py": { "maxDuration": 5 },
    "api/estate_landex_pulse.py": { "maxDuration": 5 },
    "api/estate_change_feed.py": { "maxDuration": 5 },
    "api/estate_policy_shock.py": { "maxDuration": 5 },
    "api/estate_subscription_calendar.py": { "maxDuration": 5 },
