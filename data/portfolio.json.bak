        "https://kr.investing.com/news/economy-news/article-1795675",
        "https://www.ebc.com/kr/forex/283017.html",
        "https://www.ebc.com/kr/forex/279308.html",
        "https://www.aseanexpress.co.kr/news/article.html?no=11170",
        "https://kr.investing.com/economic-calendar/boj-interest-rate-decision-165",
        "https://www.mql5.com/ko/economic-calendar/japan/boj-interest-rate-decision",
