      "multi_factor": 0.22,
      "consensus": 0.15,
      "prediction": 0.10,
      "backtest": 0.08,
      "timing": 0.07,
      "commodity_margin": 0.04,
      "export_trade": 0.08,
      "moat_quality": 0.10,
      "graham_value": 0.08,
      "canslim_growth": 0.08
