        "references": [
          "Jegadeesh & Titman 1993",
          "Moskowitz et al. 2012",
          "George & Hwang 2004"
        ]
      },
      "quality": {
        "enabled": true,
        "sub_weights": {
          "piotroski_f": 0.35,
          "gross_profitability": 0.25,
          "altman_z": 0.2,
          "earning_quality": 0.1,
          "stability": 0.1
