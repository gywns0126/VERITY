      },
      "mean_reversion": {
        "enabled": true,
        "sub_weights": {
          "zscore": 0.3,
          "rsi_reversion": 0.2,
          "bollinger": 0.15,
          "ma_deviation": 0.15,
          "hurst": 0.2
