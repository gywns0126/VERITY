          "Hurst 1951"
        ]
      }
    },
    "regime_weights": {
      "neutral": {
        "momentum": 0.1,
        "quality": 0.08,
        "volatility": 0.06,
        "mean_reversion": 0.06
      },
      "risk_off": {
        "momentum": 0.05,
        "quality": 0.14,
        "volatility": 0.1,
        "mean_reversion": 0.06
      },
